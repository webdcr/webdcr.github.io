{
  "name": "@netlify/identity",
  "version": "1.0.0",
  "type": "module",
  "description": "Headless auth functions for Netlify Identity (not the widget). Import { login, getUser } and call them. No init, no class, no UI.",
  "main": "./dist/index.cjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.cjs",
    "dist/**/*.d.ts",
    "dist/**/*.d.cts",
    "dist/**/*.map"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src test",
    "typecheck": "tsc --noEmit",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "prepack": "npm run build",
    "prepublishOnly": "npm run test",
    "prepare": "husky"
  },
  "keywords": [
    "netlify",
    "identity",
    "authentication",
    "jwt",
    "auth",
    "oauth",
    "login",
    "signup",
    "gotrue",
    "serverless",
    "edge-functions"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/netlify/identity.git"
  },
  "bugs": {
    "url": "https://github.com/netlify/identity/issues"
  },
  "author": "Netlify Inc.",
  "devDependencies": {
    "@types/node": "^22.0.0",
    "eslint": "^9.0.0",
    "husky": "^9.1.7",
    "jsdom": "^28.1.0",
    "lint-staged": "^16.2.7",
    "prettier": "^3.0.0",
    "tsup": "^8.5.0",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^4.0.0"
  },
  "lint-staged": {
    "*.{ts,js,json,md}": "prettier --write"
  },
  "dependencies": {
    "gotrue-js": "^1.0.1"
  }
}
